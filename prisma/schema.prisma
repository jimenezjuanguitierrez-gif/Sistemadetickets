generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Rol {
  ADMIN
  PROFESOR
  USER
}

enum EstadoTicket {
  ABIERTO
  EN_PROCESO
  RESUELTO
  CERRADO
}

enum Prioridad {
  BAJA
  MEDIA
  ALTA
  CRITICA
}

model User {
  id               Int         @id @default(autoincrement())
  nombre           String
  email            String      @unique
  password         String
  rol              Rol         @default(USER)
  activo           Boolean     @default(true)
  fechaCreacion    DateTime    @default(now())

  ticketsCreados   Ticket[]    @relation("TicketCreadoPor")
  ticketsAsignados Ticket[]    @relation("TicketAsignadoA")
  historial        Historial[]
}

model Computadora {
  id          Int      @id @default(autoincrement())
  codigo      String   @unique
  nombre      String
  lab         String   @default("otros")
  ubicacion   String   @default("")
  descripcion String   @default("")
  marca       String   @default("")
  modelo      String   @default("")
  procesador  String   @default("")
  ram         String   @default("")
  disco       String   @default("")
  os          String   @default("")
  estado      String   @default("ok")

  tickets     Ticket[]
}

model Ticket {
  id                 Int          @id @default(autoincrement())
  titulo             String
  descripcion        String
  estado             EstadoTicket @default(ABIERTO)
  prioridad          Prioridad    @default(MEDIA)
  fechaCreacion      DateTime     @default(now())
  fechaActualizacion DateTime     @updatedAt

  creadoPorId        Int
  creadoPor          User         @relation("TicketCreadoPor", fields: [creadoPorId], references: [id])

  asignadoAId        Int?
  asignadoA          User?        @relation("TicketAsignadoA", fields: [asignadoAId], references: [id])

  computadoraId      Int?
  computadora        Computadora? @relation(fields: [computadoraId], references: [id])

  historial          Historial[]
}

model Historial {
  id          Int      @id @default(autoincrement())
  accion      String
  descripcion String
  fecha       DateTime @default(now())

  ticketId    Int
  ticket      Ticket   @relation(fields: [ticketId], references: [id])

  usuarioId   Int
  usuario     User     @relation(fields: [usuarioId], references: [id])
}
